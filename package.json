{
  "name": "earthly",
  "version": "0.1.0",
  "private": true,
  "description": "Earthly v0.1 monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "npm --workspace @earthly/web run dev",
    "dev:server": "npm --workspace @earthly/server run dev",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:unit": "npm run test --workspaces --if-present",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test:unit && npm run test:e2e",
    "test:smoke": "node scripts/smoke.mjs",
    "doctor": "node scripts/doctor.mjs",
    "install:browsers": "playwright install chromium",
    "install:browsers:deps": "playwright install --with-deps chromium",
    "clean": "npm run clean --workspaces --if-present"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0"
  },
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  }
}
